# Copy this file to `.env` and adjust as needed.

# Secret used to sign JWTs. MUST be changed to a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-secret

# Comma-separated list of allowed frontend origins (Vite dev server default shown)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SQLite file location (relative to backend/ folder). Swap for a Postgres URL in production.
DATABASE_URL=sqlite:///./skillnetwork.db
